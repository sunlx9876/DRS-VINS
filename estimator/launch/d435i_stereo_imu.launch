<launch>
    <arg name="config_file" default="$(find drs_vins)/../config/realsense_d435i/realsense_stereo_imu_config.yaml" />
    <arg name="with_rviz" default="true" />
    <arg name="with_loop" default="false" />

    <include file="$(find drs_vins)/../config/realsense_d435i/rs_camera.launch" />

    <node name="drs_estimator" pkg="drs_vins" type="drs_vins_node" args="$(arg config_file)" output="screen" required="true" />
    <node if="$(arg with_rviz)" name="rvizvisualisation" pkg="rviz" type="rviz" output="log" args="-d $(find drs_vins)/../config/drs_vins_rviz_config.rviz" />
    <node if="$(arg with_loop)" name="loop_fusion" pkg="loop_fusion" type="loop_fusion_node" args="$(arg config_file)" output="screen" />
</launch>
